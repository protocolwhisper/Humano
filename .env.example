# Server-side World Developer Portal app id.
APP_ID=app_replace_me

# Frontend action ids. Create both in the World Developer Portal.
NEXT_PUBLIC_WORLD_ACTION_DEVICE=photo-device-proof
NEXT_PUBLIC_WORLD_ACTION_HUMAN=photo-human-proof

# Browser-only shortcut while waiting for real credentials.
# Set this to false before shipping your hackathon submission.
NEXT_PUBLIC_ALLOW_DEV_BYPASS=true

# Filecoin Calibration upload wallet for Synapse SDK.
# This wallet needs testnet funds and payment approvals before uploads succeed.
FILECOIN_WALLET_PRIVATE_KEY=0xreplace_me
FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1
